---
interface Props {
  title: string;
  description: string;
  slug: string;
  pubDate: Date;
  image?: string;
  tags?: string[];
}

const { title, description, slug, pubDate, image, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<a href={`/blog/${slug}/`} class="group block no-underline">
  <article class="glass-card card-hover rounded-xl overflow-hidden">
    {image ? (
      <div class="aspect-[3/2] overflow-hidden">
        <img
          src={image}
          alt={title}
          class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      </div>
    ) : (
      <div class="aspect-[3/2] overflow-hidden relative" style="background: linear-gradient(135deg, var(--bg-secondary), var(--bg-tertiary));">
        <div class="topo-pattern absolute inset-0 opacity-40"></div>
      </div>
    )}
    <div class="p-6">
      <time class="text-xs font-mono block mb-2" style="color: var(--text-tertiary);">{formattedDate}</time>
      <h3 class="font-heading text-lg font-semibold mb-2 heading-tight transition-colors" style="color: var(--text-primary);">
        {title}
      </h3>
      <p class="text-sm leading-relaxed line-clamp-2" style="color: var(--text-secondary);">
        {description}
      </p>
      {tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mt-4">
          {tags.map((tag) => (
            <span class="text-xs px-2.5 py-1 rounded-full font-mono" style="background: rgba(31,77,58,0.10); color: var(--accent-primary-light);">
              {tag}
            </span>
          ))}
        </div>
      )}
      <span class="text-xs font-medium mt-3 inline-flex items-center gap-1" style="color: var(--accent-primary);">
        Read more &rarr;
      </span>
    </div>
  </article>
</a>
