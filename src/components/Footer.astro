---
const year = new Date().getFullYear();
---

<footer class="border-t mt-auto py-12" style="border-color: var(--border-subtle); background: var(--bg-secondary);">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
      <div>
        <div class="flex items-center gap-2.5 mb-3">
          <svg width="20" height="20" viewBox="0 0 32 32" fill="none" aria-hidden="true">
            <path d="M8 16L16 8L24 16L16 24Z" fill="#1F4D3A"/>
            <circle cx="16" cy="16" r="3" fill="#C65D2E"/>
          </svg>
          <span class="font-heading text-lg font-bold gradient-text">Fudgeboop</span>
        </div>
        <p class="text-sm leading-relaxed" style="color: var(--text-secondary);">
          Outdoor gear reviews, trail guides, and camp setups for people who'd rather be outside.
        </p>
      </div>
      <div>
        <h4 class="font-heading text-sm font-semibold mb-3" style="color: var(--text-primary);">Pages</h4>
        <ul class="space-y-2 list-none p-0">
          <li><a href="/" class="text-sm no-underline transition-colors duration-150 hover:underline" style="color: var(--text-secondary);">Home</a></li>
          <li><a href="/blog/" class="text-sm no-underline transition-colors duration-150 hover:underline" style="color: var(--text-secondary);">Blog</a></li>
          <li><a href="/disclosure/" class="text-sm no-underline transition-colors duration-150 hover:underline" style="color: var(--text-secondary);">Affiliate Disclosure</a></li>
        </ul>
      </div>
      <div>
        <h4 class="font-heading text-sm font-semibold mb-3" style="color: var(--text-primary);">Legal</h4>
        <ul class="space-y-2 list-none p-0">
          <li><a href="/privacy/" class="text-sm no-underline transition-colors duration-150 hover:underline" style="color: var(--text-secondary);">Privacy Policy</a></li>
          <li><a href="/terms/" class="text-sm no-underline transition-colors duration-150 hover:underline" style="color: var(--text-secondary);">Terms of Service</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t pt-6 flex flex-col md:flex-row items-center justify-between gap-4" style="border-color: var(--border-subtle);">
      <p class="text-xs" style="color: var(--text-tertiary);">&copy; {year} Fudgeboop. All rights reserved.</p>
      <p class="text-xs" style="color: var(--text-tertiary);">
        This site contains affiliate links. See our <a href="/disclosure/" class="underline" style="color: var(--text-secondary);">disclosure</a>.
      </p>
    </div>
  </div>
</footer>
