---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<BaseLayout title="Fudgeboop" description="Outdoor gear reviews, trail guides, and camp setups for the adventure-obsessed.">
  <!-- Hero -->
  <section class="relative overflow-hidden" style="background: linear-gradient(180deg, var(--bg) 0%, var(--bg-secondary) 100%);">
    <div class="topo-pattern absolute inset-0"></div>
    <!-- Decorative shapes -->
    <div class="absolute top-20 right-10 w-32 h-32 rounded-full" style="background: rgba(31,77,58,0.04);"></div>
    <div class="absolute bottom-10 left-20 w-48 h-48 rounded-full" style="background: rgba(198,93,46,0.03);"></div>

    <div class="relative max-w-5xl mx-auto px-6 py-24 md:py-32 grid md:grid-cols-2 gap-12 items-center">
      <!-- Left: Text -->
      <div>
        <p class="font-mono text-xs uppercase tracking-widest mb-4" style="color: var(--accent-primary-light);">Outdoor Adventure</p>
        <h1 class="font-heading text-5xl md:text-6xl heading-tight max-w-3xl mb-6" style="color: var(--text-primary);">
          Get outside.<br />
          <span class="gradient-text">Stay out longer.</span>
        </h1>
        <p class="text-lg max-w-xl leading-relaxed mb-8" style="color: var(--text-secondary);">
          Gear reviews, trail guides, camp setups, and overlanding builds — tested in the backcountry, not a boardroom.
        </p>
        <a
          href="/blog/"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-lg font-body font-medium text-sm text-white no-underline transition-all duration-150 bg-brand-forest hover:bg-brand-forest-light active:bg-brand-forest-dark shadow-md hover:shadow-lg"
        >
          Read the blog
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>
      <!-- Right: Hero image (desktop only) -->
      <div class="relative hidden md:block">
        <div class="rounded-2xl overflow-hidden shadow-xl">
          <img
            src="https://images.unsplash.com/photo-1636138103626-8057cad9c335?w=800&q=80&auto=format&fit=crop"
            alt="Jeep driving down a dirt road with mountains in the background at sunset"
            class="w-full h-auto"
            loading="eager"
          />
        </div>
        <div class="absolute -bottom-4 -right-4 w-24 h-24 rounded-xl" style="background: var(--accent-primary); opacity: 0.08;"></div>
      </div>
    </div>
  </section>

  <!-- Latest Posts -->
  {posts.length > 0 && (
    <section class="max-w-5xl mx-auto px-6 py-16">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-heading text-2xl heading-tight" style="color: var(--text-primary);">Latest posts</h2>
        <a href="/blog/" class="text-sm font-body no-underline transition-colors" style="color: var(--text-secondary);">
          View all &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            slug={post.id}
            pubDate={post.data.pubDate}
            image={post.data.image}
            tags={post.data.tags}
          />
        ))}
      </div>
    </section>
  )}

  <!-- About / CTA -->
  <section class="max-w-5xl mx-auto px-6 py-16">
    <div class="rounded-2xl p-8 md:p-12 border-l-4 border-brand-forest" style="background: var(--bg-secondary);">
      <div class="max-w-2xl">
        <h2 class="font-heading text-2xl heading-tight mb-4" style="color: var(--text-primary);">
          Why Fudgeboop?
        </h2>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--text-secondary);">
          We test gear on real trails, real campsites, real 4x4 tracks. No paid placements, no influencer deals. Just honest takes on what actually works — from camp stoves to climbing harnesses.
        </p>
        <p class="text-sm leading-relaxed mb-6" style="color: var(--text-secondary);">
          When you buy through our links, we may earn a small commission. This keeps the site running without ads cluttering your reading experience.
        </p>
        <a href="/disclosure/" class="text-sm font-medium no-underline" style="color: var(--accent-primary);">
          Read our full disclosure &rarr;
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
